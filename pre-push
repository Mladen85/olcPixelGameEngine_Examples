#!/bin/bash

current_branch=$(git rev-parse --abbrev-ref HEAD)

# 1. Block direct push to master
if [[ "$current_branch" == "master" ]]; then
    echo "--------------------------------------------------------"
    echo "PUSH REJECTED: Forbidden action -- can't push directly to '$current_branch'"
    echo "--------------------------------------------------------"
    exit 1
fi

# 2. Check Branch Naming Convention
# Matches:
# - feature/master_Description
# - project-XXX/feature-XX/story-XX_Description
# - project-XXX/bugfix-XX_Description
VALID_REGEX="^(feature\/master_[0-9]+|project-[0-9]+\/(feature-[0-9]+\/story-[0-9]+|bugfix-[0-9]+)_[a-zA-Z0-9_-]+)$"

if [[ ! $current_branch =~ $VALID_REGEX ]]; then
    echo "--------------------------------------------------------"
    echo "PUSH REJECTED: Invalid branch name '$current_branch'"
    echo "Expected formats:"
    echo "  feature/master_<description>"
    echo "  project-XXX/feature-XX/story-XX_<description>"
    echo "  project-XXX/bugfix-XX_<description>"
    echo "--------------------------------------------------------"
    exit 1
fi

# 3. VERIFICATION CHECK: Check for unsigned commits
# Calculate commits that are on the local branch but not pushed yet.
# If there's no upstream tracking branch (new branch), check against origin/master.
upstream=$(git rev-parse --abbrev-ref @{u} 2>/dev/null)
if [ -n "$upstream" ]; then
    range="$upstream..HEAD"
else
    range="origin/master..HEAD"
fi

unsigned_commits=$(git log $range --format="%H %G?")

while read -r line; do
    # Skip empty lines
    [ -z "$line" ] && continue

    commit_hash=$(echo $line | cut -d' ' -f1)
    sig_status=$(echo $line | cut -d' ' -f2)

    # %G? is 'G' for good, 'B' for bad, 'U' for untrusted, 'N' for no signature
    if [[ "$sig_status" != "G" ]]; then
        echo "--------------------------------------------------------"
        echo "PUSH REJECTED: Unsigned commit detected!"
        echo "Commit $commit_hash is not signed or has an invalid signature."
        echo "Fix with: git commit --amend --no-edit -S"
        echo "--------------------------------------------------------"
        exit 1
    fi
done <<< "$unsigned_commits"

exit 0